#!/usr/bin/env python3
"""
Quest 3  ──WSS──▶  Python (HTTPS/aiohttp)  ──RTDE──▶  URSim / UR10

State machine:
  IDLE        ─ left  GRIP  edge  ──▶  CALIBRATED   (snapshot reference)
  CALIBRATED  ─ right GRIP  edge  ──▶  TRACKING     (servoL loop)
  TRACKING    ─ right GRIP  edge  ──▶  CALIBRATED   (servoStop, hold)
  ANY         ─ left  TRIG  edge  ──▶  HOMING       (moveL to home joints)
  ANY         ─ right TRIG  edge  ──▶  gripper open/close placeholder
  CALIBRATED/TRACKING ─ left GRIP edge ──▶  IDLE    (full reset)
"""

import asyncio, json, ssl, socket, threading, time
from pathlib import Path

import aiohttp
from aiohttp import web
import numpy as np
from scipy.spatial.transform import Rotation as R
import rtde_control
import rtde_receive

# ═══════════════════════════════════════════════════════════════════
#  CONFIGURATION
# ═══════════════════════════════════════════════════════════════════

URSIM_IP    = "127.0.0.1"
SERVER_PORT = 8443
CERT_FILE   = "cert.pem"
KEY_FILE    = "key.pem"
HTML_FILE   = "index.html"

# ── Servo loop ──────────────────────────────────────────────────────
SERVO_DT        = 0.008   # 125 Hz
SERVO_LOOKAHEAD = 0.08
SERVO_GAIN      = 300
MAX_VEL         = 0.25    # m/s
MAX_ACC         = 0.5     # m/s²

# ── Homing ──────────────────────────────────────────────────────────
# UR10 "safe upright" joint config [rad] — adjust to your cell layout
HOME_JOINTS = [0.0, -1.5708, 1.5708, -1.5708, -1.5708, 0.0]
HOME_VEL    = 0.5   # rad/s
HOME_ACC    = 0.3   # rad/s²

# ── Teleoperation ───────────────────────────────────────────────────
POS_SCALE = 0.8

# ── Workspace clamp (UR10 base frame, metres) ───────────────────────
TCP_MIN = np.array([-0.9, -0.9,  0.05])
TCP_MAX = np.array([ 0.9,  0.9,  1.10])

# ── Coordinate frame: Quest WebXR → UR10 base frame ─────────────────
COORD_R = R.from_matrix(np.array([
    [ 0,  0, -1],
    [-1,  0,  0],
    [ 0,  1,  0],
]))

# ═══════════════════════════════════════════════════════════════════
#  Shared state
# ═══════════════════════════════════════════════════════════════════

_lock = threading.Lock()
_ctrl = {"left": None, "right": None, "ts": 0.0}
_ws_clients = []

# ═══════════════════════════════════════════════════════════════════
#  aiohttp handlers
# ═══════════════════════════════════════════════════════════════════

async def handle_index(request):
    return web.FileResponse(HTML_FILE)

async def handle_ws(request):
    ws = web.WebSocketResponse(heartbeat=10.0)
    await ws.prepare(request)
    print(f"[WS ] connected  {request.remote}")
    async for msg in ws:
        if msg.type == aiohttp.WSMsgType.TEXT:
            try:
                data = json.loads(msg.data)
                with _lock:
                    _ctrl["left"]  = data.get("left")
                    _ctrl["right"] = data.get("right")
                    _ctrl["ts"]    = time.monotonic()
            except Exception:
                pass
        elif msg.type in (aiohttp.WSMsgType.CLOSED, aiohttp.WSMsgType.ERROR):
            break
    print("[WS ] disconnected")
    return ws

# ═══════════════════════════════════════════════════════════════════
#  Coordinate helpers
# ═══════════════════════════════════════════════════════════════════

def q2rp(pos: list) -> np.ndarray:
    return COORD_R.apply(np.array(pos, dtype=float))

def q2rr(quat: list) -> R:
    qr = R.from_quat(quat)
    return COORD_R * qr * COORD_R.inv()

def clamp_pose(pose: np.ndarray) -> np.ndarray:
    p = pose.copy()
    p[:3] = np.clip(p[:3], TCP_MIN, TCP_MAX)
    return p

# ═══════════════════════════════════════════════════════════════════
#  Gripper placeholder
# ═══════════════════════════════════════════════════════════════════

_gripper_open = True   # toggled on each trigger edge

def gripper_command(open_: bool):
    """
    Replace this with your real gripper driver call.
    e.g. Robotiq 2F-140 over Modbus, or a serial command.
    """
    state = "OPEN  🟢" if open_ else "CLOSE 🔴"
    print(f"[GRP ] → {state}  (placeholder — wire up your gripper here)")

# ═══════════════════════════════════════════════════════════════════
#  Teleoperation thread
# ═══════════════════════════════════════════════════════════════════

def teleop_thread():
    print(f"[UR ] Connecting to URSim @ {URSIM_IP} …")
    print( "      (Make sure the robot is powered ON in the web UI at")
    print( "       http://localhost:6080  before running this script)\n")

    ctrl = rtde_control.RTDEControlInterface(URSIM_IP)
    recv = rtde_receive.RTDEReceiveInterface(URSIM_IP)
    print(f"[UR ] Connected  TCP = {np.round(recv.getActualTCPPose(), 4)}\n")

    print("  Controls")
    print("  ─────────────────────────────────────────────────────────")
    print("  Left  GRIP  (press)         →  Calibrate reference pose")
    print("  Left  GRIP  (press again)   →  Full reset to IDLE")
    print("  Left  TRIGGER (press)       →  Home robot (safe upright)")
    print("  Right GRIP  (hold)          →  Robot tracks right controller")
    print("  Right GRIP  (release)       →  Pause (hold position)")
    print("  Right TRIGGER (press)       →  Toggle gripper open/close")
    print("  Right X button              →  (was Y) user-defined")
    print("  Right Y button              →  (was X) user-defined")
    print("  ─────────────────────────────────────────────────────────\n")

    def snapshot():
        with _lock:
            return dict(_ctrl)

    def fresh(d):
        return (time.monotonic() - d["ts"]) < 0.5

    def safe_servo_stop():
        try:
            ctrl.servoStop(a=4.0)
        except Exception:
            pass

    mode    = "IDLE"
    calib   = {}

    # Previous button states for edge detection
    lg_prev  = 0.0   # left  grip
    lt_prev  = 0.0   # left  trigger  ← NEW
    rg_prev  = 0.0   # right grip     ← replaces rt_prev for tracking
    rt_prev  = 0.0   # right trigger  ← now = gripper

    global _gripper_open

    while True:
        t0 = time.monotonic()
        d  = snapshot()

        if not fresh(d) or d["left"] is None or d["right"] is None:
            time.sleep(SERVO_DT)
            continue

        left  = d["left"]
        right = d["right"]

        # ── Button values ────────────────────────────────────────────
        lg = float(left.get("grip",    0.0))   # left  grip
        lt = float(left.get("trigger", 0.0))   # left  trigger  ← homing
        rg = float(right.get("grip",   0.0))   # right grip     ← tracking
        rt = float(right.get("trigger",0.0))   # right trigger  ← gripper

        # ── Edge detection ───────────────────────────────────────────
        lg_edge = lg > 0.5 and lg_prev <= 0.5   # left  grip  press
        lt_edge = lt > 0.5 and lt_prev <= 0.5   # left  trig  press ← NEW
        rg_on   = rg > 0.5                       # right grip  held
        rg_off  = rg <= 0.5 and rg_prev > 0.5   # right grip  release
        rt_edge = rt > 0.5 and rt_prev <= 0.5   # right trig  press ← NEW

        # ── Left TRIGGER → Home ──────────────────────────────────────
        if lt_edge:
            safe_servo_stop()
            mode  = "IDLE"
            calib = {}
            print("[UR ] Homing … (moveJ to safe upright)")
            try:
                ctrl.moveJ(HOME_JOINTS, HOME_VEL, HOME_ACC)
                print(f"[UR ] Home reached  TCP = {np.round(recv.getActualTCPPose(), 3)}")
            except Exception as e:
                print(f"[UR ] Home error: {e}")
            time.sleep(0.35)

        # ── Right TRIGGER → Gripper toggle ───────────────────────────
        elif rt_edge:
            _gripper_open = not _gripper_open
            gripper_command(_gripper_open)

        # ── Left GRIP → Calibrate / Reset ────────────────────────────
        elif lg_edge:
            if mode == "IDLE":
                home = np.array(recv.getActualTCPPose())
                calib = {
                    "r_pos": q2rp(right["pos"]),
                    "r_rot": q2rr(right["quat"]),
                    "l_pos": q2rp(left["pos"]),
                    "l_rot": q2rr(left["quat"]),
                    "home":  home,
                }
                mode = "CALIBRATED"
                print(f"[UR ] Calibrated  home = {np.round(home, 3)}")
            elif mode in ("CALIBRATED", "TRACKING"):
                safe_servo_stop()
                mode  = "IDLE"
                calib = {}
                print("[UR ] → IDLE (reset)")
            time.sleep(0.35)

        # ── Right GRIP release → Pause tracking ─────────────────────
        elif rg_off and mode == "TRACKING":
            safe_servo_stop()
            mode = "CALIBRATED"
            print("[UR ] Tracking paused")

        # ── Right GRIP held → Start / continue tracking ──────────────
        elif rg_on and mode == "CALIBRATED":
            mode = "TRACKING"
            print("[UR ] Tracking started")

        # ── ServoL when TRACKING ─────────────────────────────────────
        if mode == "TRACKING":
            r_pos_now = q2rp(right["pos"])
            r_rot_now = q2rr(right["quat"])

            delta_p = (r_pos_now - calib["r_pos"]) * POS_SCALE
            delta_r = r_rot_now * calib["r_rot"].inv()

            target_pos = calib["home"][:3] + delta_p
            target_rot = (delta_r * R.from_rotvec(calib["home"][3:6])).as_rotvec()

            target = clamp_pose(np.concatenate([target_pos, target_rot]))

            try:
                ctrl.servoL(target.tolist(),
                            MAX_VEL, MAX_ACC,
                            SERVO_DT, SERVO_LOOKAHEAD, SERVO_GAIN)
            except Exception as e:
                print(f"[UR ] servoL error: {e}")
                mode = "CALIBRATED"

        # ── Update previous states ───────────────────────────────────
        lg_prev = lg
        lt_prev = lt
        rg_prev = rg
        rt_prev = rt

        time.sleep(max(0.0, SERVO_DT - (time.monotonic() - t0)))

# ═══════════════════════════════════════════════════════════════════
#  Main
# ═══════════════════════════════════════════════════════════════════

def get_lan_ip() -> str:
    with socket.socket(socket.AF_INET, socket.SOCK_DGRAM) as s:
        try:
            s.connect(("8.8.8.8", 80))
            return s.getsockname()[0]
        except Exception:
            return "0.0.0.0"

def main():
    lan_ip = get_lan_ip()

    t = threading.Thread(target=teleop_thread, daemon=True)
    t.start()

    app = web.Application()
    app.router.add_get("/",   handle_index)
    app.router.add_get("/ws", handle_ws)

    ssl_ctx = ssl.SSLContext(ssl.PROTOCOL_TLS_SERVER)
    ssl_ctx.load_cert_chain(CERT_FILE, KEY_FILE)

    print(f"\n[SRV] Open on your Quest Meta Browser:")
    print(f"      https://{lan_ip}:{SERVER_PORT}/")
    print(f"      (tap 'Advanced → Proceed' to accept the self-signed cert)\n")

    web.run_app(app, port=SERVER_PORT, ssl_context=ssl_ctx, print=lambda *_: None)

if __name__ == "__main__":
    main()

