<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>UR10 Quest Teleop</title>
  <style>
    * { box-sizing: border-box; }
    body  { font-family: monospace; background: #0d1117; color: #c9d1d9;
            display: flex; flex-direction: column; align-items: center;
            padding: 16px; margin: 0; }
    h1    { color: #58a6ff; margin: 8px 0; font-size: 18px; }
    .card { background: #161b22; border: 1px solid #30363d; border-radius: 8px;
            padding: 12px; margin: 6px 0; width: 360px; position: relative; z-index: 10; }
    .row  { display: flex; align-items: center; gap: 8px; margin: 3px 0; }
    .dot  { width: 10px; height: 10px; border-radius: 50%; background: #f85149; flex-shrink: 0; }
    .dot.ok   { background: #3fb950; }
    .dot.warn { background: #d29922; }
    button           { background: #238636; color: #fff; border: none; border-radius: 6px;
                       padding: 9px 14px; margin: 3px; font-size: 13px; cursor: pointer; width: 100%;
                       position: relative; z-index: 10; }
    button:disabled  { background: #30363d; color: #8b949e; cursor: not-allowed; }
    button.red  { background: #da3633; }
    button.blue { background: #1f6feb; }
    pre   { font-size: 11px; color: #8b949e; line-height: 1.5; margin: 4px 0; }
    #log  { max-height: 110px; overflow-y: auto; font-size: 11px; }

    /* ── In-headset HUD ─────────────────────────────────────────── */
    #hud {
      display: none;
      position: fixed; bottom: 30px; left: 50%; transform: translateX(-50%);
      background: rgba(0,0,0,0.72); color: #fff; font-family: monospace;
      font-size: 20px; padding: 14px 22px; border-radius: 10px;
      border: 2px solid #58a6ff; text-align: center;
      z-index: 20;                        /* above canvas */
      min-width: 320px; line-height: 1.9; pointer-events: none;
    }
    #hud .big  { font-size: 26px; font-weight: bold; }
    #hud .ok   { color: #3fb950; }
    #hud .warn { color: #d29922; }

    /* ── Three.js canvas ────────────────────────────────────────── */
    #three-canvas {
      position: fixed; top: 0; left: 0;
      width: 100vw; height: 100vh;
      z-index: 0;           /* behind all HTML */
      pointer-events: none; /* ← FIX: clicks pass through to buttons */
    }
  </style>
</head>
<body>

<h1>UR10 Quest Teleop</h1>

<div class="card">
  <div class="row"><div class="dot" id="d-ws"></div><span id="l-ws">WebSocket: connecting…</span></div>
  <div class="row"><div class="dot" id="d-rv"></div><span id="l-rv">Robot viz: connecting…</span></div>
  <div class="row"><div class="dot" id="d-xr"></div><span id="l-xr">XR: not started</span></div>
  <div class="row"><div class="dot" id="d-ctrl"></div><span id="l-ctrl">Controllers: waiting…</span></div>
  <div class="row" style="margin-top:6px">
    <span style="font-size:12px;color:#8b949e">Sends/s: </span>
    <span id="hz" style="font-size:12px;color:#58a6ff">0</span>
  </div>
</div>

<div class="card">
  <button id="btn-ar">▶ Enter AR (overlay + robot viz)</button>
  <button id="btn-vr" class="blue">▶ Enter VR (robot viz, no passthrough)</button>
  <button id="btn-stop" class="red" disabled>■ Exit session</button>
</div>

<div class="card">
  <pre id="p-left">Left:  —</pre>
  <pre id="p-right">Right: —</pre>
  <pre id="p-robot">Robot: —</pre>
</div>

<div class="card">
  <strong>Controls</strong>
  <pre>Left  GRIP  → Calibrate / Reset
Left  TRIG  → Home robot
Right GRIP  → Track (hold)
Right TRIG  → Toggle gripper</pre>
</div>

<div class="card"><strong>Log</strong><div id="log"></div></div>

<div id="hud">
  <div class="big" id="hud-mode">● IDLE</div>
  <div id="hud-ctrl">Controllers: —</div>
  <div id="hud-tcp" style="font-size:14px;color:#8b949e">TCP: —</div>
</div>

<script type="importmap">
{
  "imports": {
    "three": "https://cdn.jsdelivr.net/npm/three@0.162.0/build/three.module.js"
  }
}
</script>

<script type="module">
import * as THREE from 'three';

/* ══════════════════════════════════════════════════════════════════
   CONFIG
══════════════════════════════════════════════════════════════════ */
const WS_URL       = `wss://${location.host}/ws`;
const ROBOT_WS_URL = `wss://${location.host}/robot_ws`;
const SEND_INTERVAL = 1000 / 90;

/* ── UR10 DH parameters (standard DH, metres) ──────────────────────
   [a_i, d_i, alpha_i]  —  theta_i added per joint at runtime
*/
const UR10_DH = [
  { a:  0.000, d:  0.1273, alpha:  Math.PI/2  },
  { a: -0.6120,d:  0.0000, alpha:  0          },
  { a: -0.5723,d:  0.0000, alpha:  0          },
  { a:  0.000, d:  0.1639, alpha:  Math.PI/2  },
  { a:  0.000, d:  0.1157, alpha: -Math.PI/2  },
  { a:  0.000, d:  0.0922, alpha:  0          },
];
const HOME_Q = [0, -Math.PI/2, Math.PI/2, -Math.PI/2, -Math.PI/2, 0];

/* ══════════════════════════════════════════════════════════════════
   RENDERER  — canvas appended BEFORE body content so z-order works
══════════════════════════════════════════════════════════════════ */
const renderer = new THREE.WebGLRenderer({ antialias: true, alpha: true });
renderer.setPixelRatio(window.devicePixelRatio);
renderer.setSize(window.innerWidth, window.innerHeight);
renderer.xr.enabled = true;
renderer.domElement.id = 'three-canvas';
// Insert canvas as FIRST child so CSS z-index:0 puts it behind HTML
document.body.insertBefore(renderer.domElement, document.body.firstChild);

const scene  = new THREE.Scene();
const camera = new THREE.PerspectiveCamera(70, window.innerWidth / window.innerHeight, 0.01, 20);
scene.add(new THREE.AmbientLight(0xffffff, 0.7));
const sun = new THREE.DirectionalLight(0xffffff, 0.8);
sun.position.set(1, 3, 2);
scene.add(sun);

/* ── Robot root group ───────────────────────────────────────────────
   Position this in front of the user at table height.
   robotRoot uses UR convention: Z-up. We rotate it so Z-up → Y-up.
*/
const ROBOT_ORIGIN = new THREE.Vector3(0, -0.3, -1.2);
const robotRoot = new THREE.Group();
robotRoot.position.copy(ROBOT_ORIGIN);
robotRoot.rotation.x = -Math.PI / 2;   // Z-up → Y-up
scene.add(robotRoot);

/* ── Materials ──────────────────────────────────────────────────── */
const M_LINK  = new THREE.MeshPhongMaterial({ color: 0x2a5caa, transparent: true, opacity: 0.88 });
const M_JNT   = new THREE.MeshPhongMaterial({ color: 0xcccccc });
const M_TCP   = new THREE.MeshPhongMaterial({ color: 0x3fb950, transparent: true, opacity: 0.9 });
const M_GHOST = new THREE.MeshPhongMaterial({ color: 0xf0a020, transparent: true, opacity: 0.60 });
const M_BASE  = new THREE.MeshPhongMaterial({ color: 0x444444 });
const M_AX_X  = new THREE.MeshBasicMaterial({ color: 0xff4444 });
const M_AX_Z  = new THREE.MeshBasicMaterial({ color: 0x44ff44 });
const M_LINE  = new THREE.LineBasicMaterial({ color: 0x4a8aee, linewidth: 3 });

/* ── Helpers ─────────────────────────────────────────────────────── */
const mkSphere = (r, m) => new THREE.Mesh(new THREE.SphereGeometry(r,16,12), m);
const mkCyl    = (r, h, m) => new THREE.Mesh(new THREE.CylinderGeometry(r,r,h,16), m);
const mkBox    = (w,h,d,m) => new THREE.Mesh(new THREE.BoxGeometry(w,h,d), m);

/* ── Base pedestal ───────────────────────────────────────────────── */
robotRoot.add(Object.assign(mkBox(0.22,0.12,0.22, M_BASE), { position: new THREE.Vector3(0,0.06,0) }));

/* ── Joint spheres (7 = base + 6 joints) ────────────────────────── */
// All added directly to robotRoot; positioned by FK every frame
const jointSpheres = Array.from({length: 7}, (_, i) =>
  mkSphere(i === 0 ? 0.06 : 0.046, M_JNT));
jointSpheres.forEach(s => robotRoot.add(s));

/* ── Link cylinders between joint pairs ──────────────────────────── */
// 6 cylinders: joint0→1, 1→2, ..., 5→tcp
// Rebuilt in geometry each frame — simpler than DH parenting
const LINK_RADII = [0.052, 0.040, 0.036, 0.030, 0.028, 0.026];
const linkMeshes = LINK_RADII.map(r => {
  const m = mkCyl(r, 1.0, M_LINK.clone());   // height overridden each frame
  robotRoot.add(m);
  return m;
});

/* ── TCP marker ──────────────────────────────────────────────────── */
const tcpMarker = mkSphere(0.042, M_TCP);
const axX = mkCyl(0.005, 0.14, M_AX_X); axX.rotation.z = -Math.PI/2; axX.position.x = 0.07;
const axZ = mkCyl(0.005, 0.14, M_AX_Z); axZ.position.y = 0.07;
tcpMarker.add(axX, axZ);
robotRoot.add(tcpMarker);

/* ── Right controller ghost ──────────────────────────────────────── */
const ctrlGhost = mkSphere(0.033, M_GHOST);
ctrlGhost.visible = false;
scene.add(ctrlGhost);   // world space

/* ── Grid + workspace box ────────────────────────────────────────── */
scene.add(Object.assign(new THREE.GridHelper(4, 20, 0x334455, 0x223344),
  { position: new THREE.Vector3(0, ROBOT_ORIGIN.y - 0.01, 0) }));

const wsEdges = new THREE.LineSegments(
  new THREE.EdgesGeometry(new THREE.BoxGeometry(1.8, 1.05, 1.8)),
  new THREE.LineBasicMaterial({ color: 0x334455, transparent: true, opacity: 0.25 }));
wsEdges.position.set(0, 0.575, 0);
robotRoot.add(wsEdges);

/* ══════════════════════════════════════════════════════════════════
   FORWARD KINEMATICS
   Returns array of 7 THREE.Vector3 positions in robotRoot local space:
   [base=origin, j1, j2, j3, j4, j5, tcp]
   and the final quaternion at TCP.
══════════════════════════════════════════════════════════════════ */
function fkPositions(joints) {
  // Build cumulative 4×4 transforms via DH
  // DH: T_i = Rz(θ) · Tz(d) · Tx(a) · Rx(α)
  let mat = new THREE.Matrix4();   // identity = robotRoot origin

  const positions = [new THREE.Vector3(0, 0, 0)];  // joint 0 = base origin
  const tmp = new THREE.Matrix4();

  for (let i = 0; i < 6; i++) {
    const { a, d, alpha } = UR10_DH[i];
    const theta = joints[i];

    const ct = Math.cos(theta), st = Math.sin(theta);
    const ca = Math.cos(alpha), sa = Math.sin(alpha);

    // Standard DH 4×4 (column-major for THREE.Matrix4)
    tmp.set(
      ct, -st*ca,  st*sa, a*ct,
      st,  ct*ca, -ct*sa, a*st,
       0,     sa,     ca,    d,
       0,      0,      0,    1
    );

    mat = mat.clone().multiply(tmp);

    const p = new THREE.Vector3();
    p.setFromMatrixPosition(mat);
    positions.push(p);
  }

  // TCP orientation quaternion
  const tcpQuat = new THREE.Quaternion();
  tcpQuat.setFromRotationMatrix(mat);

  return { positions, tcpQuat };
}

/* Update all visual elements to match joint state */
function applyFK(joints) {
  const { positions, tcpQuat } = fkPositions(joints);

  // Place joint spheres
  for (let i = 0; i < 7; i++) {
    jointSpheres[i].position.copy(positions[i]);
  }

  // Place + orient link cylinders between consecutive joints
  for (let i = 0; i < 6; i++) {
    const a = positions[i];
    const b = positions[i + 1];

    const mid = new THREE.Vector3().addVectors(a, b).multiplyScalar(0.5);
    const len = a.distanceTo(b);

    if (len < 0.001) { linkMeshes[i].visible = false; continue; }
    linkMeshes[i].visible = true;

    // Rebuild geometry with correct height (avoids scale distortion on end caps)
    linkMeshes[i].geometry.dispose();
    linkMeshes[i].geometry = new THREE.CylinderGeometry(LINK_RADII[i], LINK_RADII[i], len, 16);

    linkMeshes[i].position.copy(mid);

    // Orient cylinder (default axis = Y) to point from a → b
    const dir = new THREE.Vector3().subVectors(b, a).normalize();
    const axis = new THREE.Vector3(0, 1, 0);
    linkMeshes[i].quaternion.setFromUnitVectors(axis, dir);
  }

  // TCP marker
  tcpMarker.position.copy(positions[6]);
  tcpMarker.quaternion.copy(tcpQuat);
}

applyFK(HOME_Q);

/* ══════════════════════════════════════════════════════════════════
   WEBSOCKETS
══════════════════════════════════════════════════════════════════ */
let ws = null, lastSendTs = 0, sendCount = 0, hzTimer = null;

function connectWS() {
  ws = new WebSocket(WS_URL);
  ws.onopen  = () => { setDot('d-ws','ok'); setText('l-ws','WebSocket: connected');
                       en('btn-ar'); en('btn-vr'); log('WS connected'); };
  ws.onclose = () => { setDot('d-ws',''); setText('l-ws','WebSocket: reconnecting…');
                       dis('btn-ar'); dis('btn-vr'); setTimeout(connectWS, 2000); };
  ws.onerror = () => log('WS error');
}

let robotWs = null;
function connectRobotWS() {
  robotWs = new WebSocket(ROBOT_WS_URL);
  robotWs.onopen    = () => { setDot('d-rv','ok'); setText('l-rv','Robot viz: connected'); };
  robotWs.onclose   = () => { setDot('d-rv',''); setText('l-rv','Robot viz: reconnecting…');
                              setTimeout(connectRobotWS, 2000); };
  robotWs.onerror   = () => {};
  robotWs.onmessage = (ev) => {
    try {
      const d = JSON.parse(ev.data);
      if (d.joints && d.joints.length === 6) {
        applyFK(d.joints);
      }
      if (d.tcp) {
        const t = d.tcp;
        setText('p-robot',
          `TCP: [${t.slice(0,3).map(v=>v.toFixed(3)).join(', ')}]\n` +
          `Ori: [${t.slice(3,6).map(v=>v.toFixed(3)).join(', ')}]\n` +
          `Mode: ${d.mode ?? '?'}`);
        setText('hud-tcp',
          `TCP [${t[0].toFixed(2)}, ${t[1].toFixed(2)}, ${t[2].toFixed(2)}]  ${d.mode ?? ''}`);
        const modeEl = document.getElementById('hud-mode');
        modeEl.textContent = `● ${d.mode ?? 'IDLE'}`;
        modeEl.className = 'big ' + (d.mode === 'TRACKING' ? 'ok' : d.mode === 'CALIBRATED' ? 'warn' : '');
      }
    } catch(_) {}
  };
}

/* ══════════════════════════════════════════════════════════════════
   XR SESSION
══════════════════════════════════════════════════════════════════ */
let xrSession = null, refSpace = null, domOverlay = false;
const hud = document.getElementById('hud');

document.getElementById('btn-ar').onclick   = () => startXR('ar');
document.getElementById('btn-vr').onclick   = () => startXR('vr');
document.getElementById('btn-stop').onclick = () => xrSession?.end();

async function startXR(prefer) {
  if (!navigator.xr) { log('WebXR not supported'); return; }

  let mode, opts;
  if (prefer === 'ar' && await navigator.xr.isSessionSupported('immersive-ar')) {
    mode = 'immersive-ar';
    opts = { requiredFeatures: ['local-floor'],
             optionalFeatures: ['dom-overlay','hand-tracking'],
             domOverlay: { root: document.body } };
  } else {
    mode = 'immersive-vr';
    if (!await navigator.xr.isSessionSupported('immersive-vr')) { log('No XR mode'); return; }
    opts = { requiredFeatures: ['local-floor'], optionalFeatures: ['hand-tracking'] };
  }

  for (const rf of ['local-floor','local']) {
    try {
      opts.requiredFeatures = [rf];
      xrSession = await navigator.xr.requestSession(mode, opts);
      log(`Session: ${mode}/${rf}`); break;
    } catch(e) {
      if (rf === 'local') { log('Session failed: '+e.message); return; }
    }
  }

  domOverlay = xrSession.domOverlayState?.type != null;
  if (domOverlay) hud.style.display = 'block';

  await renderer.xr.setSession(xrSession);

  try { refSpace = await xrSession.requestReferenceSpace('local-floor'); }
  catch(_) { refSpace = await xrSession.requestReferenceSpace('local'); }

  xrSession.addEventListener('inputsourceschange', (ev) => {
    log(`inputsourceschange +${ev.added.length}/-${ev.removed.length} total:${xrSession.inputSources.length}`);
    for (const s of ev.added) log(`  ✓ [${s.handedness}] ${s.profiles[0]??'?'}`);
  });
  xrSession.addEventListener('selectstart', ev => log(`selectstart: ${ev.inputSource.handedness}`));

  xrSession.addEventListener('end', () => {
    hud.style.display = 'none'; domOverlay = false;
    setDot('d-xr',''); setText('l-xr','XR: ended');
    dis('btn-stop'); en('btn-ar'); en('btn-vr');
    clearInterval(hzTimer); log('Session ended');
  });

  setDot('d-xr','ok'); setText('l-xr',`XR: ${mode}${domOverlay?' +overlay':''}`);
  en('btn-stop'); dis('btn-ar'); dis('btn-vr');
  hzTimer = setInterval(() => { setText('hz', sendCount); sendCount = 0; }, 1000);
  log('*** Squeeze both controllers ***');
}

/* ── Controller read ─────────────────────────────────────────────── */
function readController(frame, src) {
  const space = src.gripSpace ?? src.targetRaySpace;
  if (!space) return null;
  const pose = frame.getPose(space, refSpace);
  if (!pose) return null;
  const t = pose.transform, gp = src.gamepad;
  return {
    pos:        [t.position.x,    t.position.y,    t.position.z],
    quat:       [t.orientation.x, t.orientation.y, t.orientation.z, t.orientation.w],
    hasGrip:    !!src.gripSpace,
    trigger:    gp?.buttons[0]?.value   ?? 0,
    grip:       gp?.buttons[1]?.value   ?? 0,
    thumbstick: [gp?.axes?.[2]??0, gp?.axes?.[3]??0],
    btn_a:      gp?.buttons[4]?.pressed ?? false,
    btn_b:      gp?.buttons[5]?.pressed ?? false,
  };
}

/* ══════════════════════════════════════════════════════════════════
   RENDER LOOP
══════════════════════════════════════════════════════════════════ */
renderer.setAnimationLoop((ts, frame) => {
  if (!frame || !xrSession || !refSpace) {
    renderer.render(scene, camera);
    return;
  }

  // Sync camera to headset view
  const vp = frame.getViewerPose(refSpace);
  if (vp) {
    const v = vp.views[0];
    camera.matrix.fromArray(v.transform.matrix);
    camera.matrix.decompose(camera.position, camera.quaternion, camera.scale);
    camera.projectionMatrix.fromArray(v.projectionMatrix);
    camera.projectionMatrixInverse.copy(camera.projectionMatrix).invert();
  }

  // Controllers
  let left = null, right = null;
  const nSrc = xrSession.inputSources.length;
  for (const src of xrSession.inputSources) {
    if (src.handedness === 'left')  left  = readController(frame, src);
    if (src.handedness === 'right') right = readController(frame, src);
  }

  // Ghost controller sphere
  if (right) {
    ctrlGhost.visible = true;
    ctrlGhost.position.set(...right.pos);
    ctrlGhost.quaternion.set(right.quat[0], right.quat[1], right.quat[2], right.quat[3]);
  } else {
    ctrlGhost.visible = false;
  }

  // Status dots
  const hasCtrl = !!(left || right);
  setDot('d-ctrl', hasCtrl ? 'ok' : (nSrc>0 ? 'warn' : ''));
  setText('l-ctrl', hasCtrl
    ? `Controllers: tracking ✓ (${nSrc})`
    : (nSrc>0 ? `${nSrc} src — squeeze harder` : 'Not detected'));
  if (domOverlay) {
    const el = document.getElementById('hud-ctrl');
    el.textContent = hasCtrl ? '🟢 Controllers tracking' : '🟡 Squeeze controllers';
    el.className   = hasCtrl ? 'ok' : 'warn';
  }

  if (left)  setText('p-left',  `L [${left.pos.map(v=>v.toFixed(3)).join(', ')}]  grip:${left.grip.toFixed(2)}`);
  if (right) setText('p-right', `R [${right.pos.map(v=>v.toFixed(3)).join(', ')}]  trig:${right.trigger.toFixed(2)}`);

  // Send controller data to Python
  if (ws?.readyState === WebSocket.OPEN && (ts - lastSendTs) >= SEND_INTERVAL) {
    ws.send(JSON.stringify({ left, right, ts }));
    lastSendTs = ts;
    sendCount++;
  }

  renderer.render(scene, camera);
});

/* ── Helpers ─────────────────────────────────────────────────────── */
const setDot  = (id, cls) =>
  document.getElementById(id).className = 'dot' + (cls ? ' '+cls : '');
const setText = (id, txt) => { const e = document.getElementById(id); if(e) e.textContent = txt; };
const en      = (id) => { const e = document.getElementById(id); if(e) e.disabled = false; };
const dis     = (id) => { const e = document.getElementById(id); if(e) e.disabled = true;  };
function log(msg) {
  const el = document.getElementById('log');
  const t  = new Date().toLocaleTimeString();
  el.innerHTML = `<div>[${t}] ${msg}</div>` + el.innerHTML.slice(0, 2400);
  console.log(`[${t}] ${msg}`);
}

window.addEventListener('resize', () => {
  camera.aspect = window.innerWidth / window.innerHeight;
  camera.updateProjectionMatrix();
  renderer.setSize(window.innerWidth, window.innerHeight);
});

connectWS();
connectRobotWS();
log('Page loaded');
</script>
</body>
</html>

