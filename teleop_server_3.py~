#!/usr/bin/env python3
"""
Quest 3  ──WSS──▶  Python (HTTPS/aiohttp)  ──RTDE──▶  URSim / UR10
                              │
                         /robot_ws  (30 Hz push: joints + TCP + mode)
                              │
                         Quest 3 Three.js viz
"""

import asyncio, json, ssl, socket, threading, time
import aiohttp
from aiohttp import web
import numpy as np
from scipy.spatial.transform import Rotation as R
import rtde_control
import rtde_receive

# ═══════════════════════════════════════════════════════════════════
#  CONFIGURATION
# ═══════════════════════════════════════════════════════════════════

URSIM_IP    = "127.0.0.1"
SERVER_PORT = 8443
CERT_FILE   = "cert.pem"
KEY_FILE    = "key.pem"
HTML_FILE   = "index_3.html"

SERVO_DT        = 0.008
SERVO_LOOKAHEAD = 0.08
SERVO_GAIN      = 300
MAX_VEL         = 0.25
MAX_ACC         = 0.5

HOME_JOINTS = [0.0, -1.5708, 1.5708, -1.5708, -1.5708, 0.0]
HOME_VEL    = 0.5
HOME_ACC    = 0.3

POS_SCALE = 0.8
TCP_MIN = np.array([-0.9, -0.9,  0.05])
TCP_MAX = np.array([ 0.9,  0.9,  1.10])

COORD_R = R.from_matrix(np.array([
    [ 0,  0,  1],
    [ 1,  0,  0],
    [ 0,  1,  0],
]))

# ═══════════════════════════════════════════════════════════════════
#  Shared state
# ═══════════════════════════════════════════════════════════════════

_lock  = threading.Lock()
_ctrl  = {"left": None, "right": None, "ts": 0.0}

_teleop_mode = "IDLE"          # read by broadcast coroutine

_viz_clients      : set = set()
_viz_clients_lock = threading.Lock()

_recv_ref = None   # set in main(), read by broadcast

# ═══════════════════════════════════════════════════════════════════
#  aiohttp handlers
# ═══════════════════════════════════════════════════════════════════

async def handle_index(request):
    return web.FileResponse(HTML_FILE)

async def handle_ws(request):
    ws = web.WebSocketResponse(heartbeat=10.0)
    await ws.prepare(request)
    print(f"[WS ] connected  {request.remote}")
    async for msg in ws:
        if msg.type == aiohttp.WSMsgType.TEXT:
            try:
                data = json.loads(msg.data)
                with _lock:
                    _ctrl["left"]  = data.get("left")
                    _ctrl["right"] = data.get("right")
                    _ctrl["ts"]    = time.monotonic()
            except Exception:
                pass
        elif msg.type in (aiohttp.WSMsgType.CLOSED, aiohttp.WSMsgType.ERROR):
            break
    print("[WS ] disconnected")
    return ws

async def handle_robot_ws(request):
    """30 Hz robot state push → Three.js viewer."""
    ws = web.WebSocketResponse(heartbeat=5.0)
    await ws.prepare(request)
    with _viz_clients_lock:
        _viz_clients.add(ws)
    print(f"[VIZ] viewer connected  {request.remote}")
    async for _ in ws:
        pass   # client is receive-only
    with _viz_clients_lock:
        _viz_clients.discard(ws)
    print("[VIZ] viewer disconnected")
    return ws

# ═══════════════════════════════════════════════════════════════════
#  30 Hz robot state broadcaster
# ═══════════════════════════════════════════════════════════════════

async def broadcast_robot_state():
    global _recv_ref, _teleop_mode
    while True:
        await asyncio.sleep(1 / 30)
        if _recv_ref is None:
            continue
        try:
            joints = list(_recv_ref.getActualQ())
            tcp    = list(_recv_ref.getActualTCPPose())
        except Exception:
            continue
        payload = json.dumps({"joints": joints, "tcp": tcp, "mode": _teleop_mode})
        dead = set()
        with _viz_clients_lock:
            clients = set(_viz_clients)
        for client in clients:
            try:
                await client.send_str(payload)
            except Exception:
                dead.add(client)
        if dead:
            with _viz_clients_lock:
                _viz_clients.difference_update(dead)   # ← was: _viz_clients -= dead


# ═══════════════════════════════════════════════════════════════════
#  Coordinate helpers
# ═══════════════════════════════════════════════════════════════════

def q2rp(pos):
    return COORD_R.apply(np.array(pos, dtype=float))

def q2rr(quat):
    return COORD_R * R.from_quat(quat) * COORD_R.inv()

def clamp_pose(pose):
    p = pose.copy()
    p[:3] = np.clip(p[:3], TCP_MIN, TCP_MAX)
    return p

# ═══════════════════════════════════════════════════════════════════
#  Gripper placeholder
# ═══════════════════════════════════════════════════════════════════

_gripper_open = True

def gripper_command(open_):
    state = "OPEN  🟢" if open_ else "CLOSE 🔴"
    print(f"[GRP ] → {state}  (placeholder)")

# ═══════════════════════════════════════════════════════════════════
#  Teleoperation thread
# ═══════════════════════════════════════════════════════════════════

def teleop_thread():
    global _teleop_mode, _recv_ref, _gripper_open

    print(f"[UR ] Connecting to URSim @ {URSIM_IP} …")
    print( "      (Make sure the robot is powered ON at http://localhost:6080)\n")

    ctrl = rtde_control.RTDEControlInterface(URSIM_IP)
    recv = rtde_receive.RTDEReceiveInterface(URSIM_IP)
    _recv_ref = recv
    print(f"[UR ] Connected  TCP = {np.round(recv.getActualTCPPose(), 4)}\n")

    print("  Controls")
    print("  ─────────────────────────────────────────────────────────")
    print("  Left  GRIP  (press)         →  Calibrate reference pose")
    print("  Left  GRIP  (press again)   →  Full reset to IDLE")
    print("  Left  TRIGGER               →  Home robot")
    print("  Right GRIP  (hold)          →  Track right controller")
    print("  Right GRIP  (release)       →  Pause")
    print("  Right TRIGGER               →  Toggle gripper")
    print("  ─────────────────────────────────────────────────────────\n")

    def snapshot():
        with _lock:
            return dict(_ctrl)

    def fresh(d):
        return (time.monotonic() - d["ts"]) < 0.5

    def safe_servo_stop():
        try:   ctrl.servoStop(a=4.0)
        except Exception: pass

    def set_mode(m):
        global _teleop_mode
        _teleop_mode = m
        return m

    mode   = set_mode("IDLE")
    calib  = {}
    lg_prev = lt_prev = rg_prev = rt_prev = 0.0

    while True:
        t0 = time.monotonic()
        d  = snapshot()

        if not fresh(d) or d["left"] is None or d["right"] is None:
            time.sleep(SERVO_DT)
            continue

        left  = d["left"]
        right = d["right"]

        lg = float(left.get("grip",    0.0))
        lt = float(left.get("trigger", 0.0))
        rg = float(right.get("grip",   0.0))
        rt = float(right.get("trigger",0.0))

        lg_edge = lg > 0.5 and lg_prev <= 0.5
        lt_edge = lt > 0.5 and lt_prev <= 0.5
        rg_on   = rg > 0.5
        rg_off  = rg <= 0.5 and rg_prev > 0.5
        rt_edge = rt > 0.5 and rt_prev <= 0.5

        if lt_edge:
            safe_servo_stop()
            mode = set_mode("IDLE")
            calib = {}
            print("[UR ] Homing …")
            try:
                ctrl.moveJ(HOME_JOINTS, HOME_VEL, HOME_ACC)
                print(f"[UR ] Home reached  TCP = {np.round(recv.getActualTCPPose(), 3)}")
            except Exception as e:
                print(f"[UR ] Home error: {e}")
            time.sleep(0.35)

        elif rt_edge:
            _gripper_open = not _gripper_open
            gripper_command(_gripper_open)

        elif lg_edge:
            if mode == "IDLE":
                home = np.array(recv.getActualTCPPose())
                calib = {
                    "r_pos": q2rp(right["pos"]),
                    "r_rot": q2rr(right["quat"]),
                    "l_pos": q2rp(left["pos"]),
                    "l_rot": q2rr(left["quat"]),
                    "home":  home,
                }
                mode = set_mode("CALIBRATED")
                print(f"[UR ] Calibrated  home = {np.round(home, 3)}")
            elif mode in ("CALIBRATED", "TRACKING"):
                safe_servo_stop()
                mode = set_mode("IDLE")
                calib = {}
                print("[UR ] → IDLE (reset)")
            time.sleep(0.35)

        elif rg_off and mode == "TRACKING":
            safe_servo_stop()
            mode = set_mode("CALIBRATED")
            print("[UR ] Tracking paused")

        elif rg_on and mode == "CALIBRATED":
            mode = set_mode("TRACKING")
            print("[UR ] Tracking started")

        if mode == "TRACKING":
            r_pos_now = q2rp(right["pos"])
            r_rot_now = q2rr(right["quat"])
            delta_p   = (r_pos_now - calib["r_pos"]) * POS_SCALE
            delta_r   = r_rot_now * calib["r_rot"].inv()
            target_pos = calib["home"][:3] + delta_p
            target_rot = (delta_r * R.from_rotvec(calib["home"][3:6])).as_rotvec()
            target = clamp_pose(np.concatenate([target_pos, target_rot]))
            try:
                ctrl.servoL(target.tolist(), MAX_VEL, MAX_ACC,
                            SERVO_DT, SERVO_LOOKAHEAD, SERVO_GAIN)
            except Exception as e:
                print(f"[UR ] servoL error: {e}")
                mode = set_mode("CALIBRATED")

        lg_prev, lt_prev, rg_prev, rt_prev = lg, lt, rg, rt
        time.sleep(max(0.0, SERVO_DT - (time.monotonic() - t0)))

# ═══════════════════════════════════════════════════════════════════
#  Main
# ═══════════════════════════════════════════════════════════════════

def get_lan_ip():
    with socket.socket(socket.AF_INET, socket.SOCK_DGRAM) as s:
        try:
            s.connect(("8.8.8.8", 80))
            return s.getsockname()[0]
        except Exception:
            return "0.0.0.0"

def main():
    lan_ip = get_lan_ip()

    threading.Thread(target=teleop_thread, daemon=True).start()

    app = web.Application()
    app.router.add_get("/",         handle_index)
    app.router.add_get("/ws",       handle_ws)
    app.router.add_get("/robot_ws", handle_robot_ws)

    async def on_startup(_):
        asyncio.ensure_future(broadcast_robot_state())
    app.on_startup.append(on_startup)

    ssl_ctx = ssl.SSLContext(ssl.PROTOCOL_TLS_SERVER)
    ssl_ctx.load_cert_chain(CERT_FILE, KEY_FILE)

    print(f"\n[SRV] Open on your Quest Meta Browser:")
    print(f"      https://{lan_ip}:{SERVER_PORT}/")
    print(f"      (tap 'Advanced → Proceed' to accept the self-signed cert)\n")

    web.run_app(app, port=SERVER_PORT, ssl_context=ssl_ctx, print=lambda *_: None)

if __name__ == "__main__":
    main()

